# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                      # development | staging | production
APP_NAME="VisionDx API"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=change-me-to-a-very-long-random-string-in-production
# JSON array of allowed origins (Next.js dev is :3000)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","https://vision-dx-tawny.vercel.app/"]

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://visiondx:password@localhost:5432/visiondx
SYNC_DATABASE_URL=postgresql+psycopg2://visiondx:password@localhost:5432/visiondx

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                    # local | s3
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_MB=10

# AWS / MinIO (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=visiondx-images
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT_URL=                     # leave empty for real AWS; set for MinIO

# ── AI Inference ──────────────────────────────────────────────────────────────
INFERENCE_BACKEND=microservice           # microservice | local
INFERENCE_SERVICE_URL=http://localhost:8001
INFERENCE_TIMEOUT_SECONDS=30
CONFIDENCE_THRESHOLD=0.35

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
