# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_replace_with_64_char_random_hex_string_here_XXXXXXXXXX

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Database ───────────────────────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_strong_db_password_here
DATABASE_URL=postgresql+asyncpg://visiondx:${DB_PASSWORD}@db:5432/visiondx
SYNC_DATABASE_URL=postgresql+psycopg2://visiondx:${DB_PASSWORD}@db:5432/visiondx

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads
MAX_IMAGE_SIZE_MB=10

# ── AWS S3 (set STORAGE_BACKEND=s3 and fill these to use S3 instead of local) ─
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=visiondx-images
# AWS_S3_REGION=us-east-1

# ── AI Inference ───────────────────────────────────────────────────────────────
INFERENCE_BACKEND=local
CONFIDENCE_THRESHOLD=0.35

# ── Observability ──────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxxx@sentry.io/yyyy
LOG_LEVEL=INFO

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
